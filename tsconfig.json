{
	"compilerOptions": {
		"skipLibCheck": true,
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"strict": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"lib": ["DOM", "DOM.Iterable", "ES2020", "ES2021.String"]
	},
	"include": ["src/**/*.ts"]
}
